# BrainyCat Configuration
# Copy this to .env and edit as needed

# ── Required ──────────────────────────────────────────────────────────────
# Secret key for session cookies (auto-generated on first run if empty)
BRAINYCAT_SECRET_KEY=

# ── Optional — these have sensible defaults ───────────────────────────────
# Port to expose (default: 8000)
BRAINYCAT_PORT=8000

# Database URL (default: built-in PostgreSQL from docker-compose.standalone.yml)
# BRAINYCAT_DATABASE_URL=postgresql://brainycat:brainycat@postgres:5432/brainycat

# Data directory inside container (default: /data)
# BRAINYCAT_DATA_DIR=/data

# Incoming folder for auto-import (default: /data/incoming)
# BRAINYCAT_INCOMING_DIR=/data/incoming

# ── Optional — external services ──────────────────────────────────────────
# Intello AI server (TTS, STT, OCR, LLM) — leave empty to disable AI features
# BRAINYCAT_INTELLO_URL=http://intello:8000

# SMTP for Kindle delivery
# BRAINYCAT_SMTP_HOST=smtp.gmail.com
# BRAINYCAT_SMTP_PORT=587

# Signal notifications
# BRAINYCAT_SIGNAL_API_URL=
